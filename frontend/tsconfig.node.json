{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "types": ["node"],
    "outDir": ".tsbuild",
    "tsBuildInfoFile": ".tsbuild/node.tsbuildinfo"
  },
  "include": ["vite.config.ts"]
}
