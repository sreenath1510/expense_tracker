# Local dev defaults. Copy this to .env if you want to override anything.

# SQLite file path. The file is created automatically on first run.
# For future hosted deployment, swap in a Postgres URL, e.g.:
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./finance.db

# Comma-separated origins allowed to call the API. Vite dev server defaults
# to port 5173. Add your prod frontend URL here when you deploy.
CORS_ORIGINS=http://localhost:5173

# --- Auth -------------------------------------------------------------------
# Signs the JWTs. MUST be a long random string in production.
SECRET_KEY=dev-secret-change-me-in-production
# How long an issued token stays valid (minutes). Default: one week.
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Credentials for the user seeded by `python -m scripts.init_db` on a fresh DB.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ledger
